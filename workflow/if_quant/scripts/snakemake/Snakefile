# Specify path to config file
configfile: 'config/config.yaml'

# Prep sampletable
sample = pd.read_table(config['sampletable']).set_index('samplename', drop=False)

# Filter rows for fluorescence images
multi_channel = sample[sample['channel'] == "multi"]

def get_chunksize(wildcards):
    """
    Safely calculates the chunk size as 1/8th of the smaller spatial dimension
    of the largest resolution series inside a pyramidal TIFF.
    """
    import os
    import tifffile

    tif_path = os.path.join(config['out_converted'], wildcards.name, "converted.ome.tif")
    default_chunk = config.get('chunk_size', 5000)

    # Dry-run or pre-conversion safety check
    if not os.path.exists(tif_path):
        return default_chunk

    try:
        with tifffile.TiffFile(tif_path) as tif:
            max_area = 0
            best_shape = None
            
            # Iterate through all resolution levels (series)
            for series in tif.series:
                shape = series.shape
                axes = series.axes
                dims = dict(zip(axes, shape))
                
                # Retrieve spatial dimensions
                height = dims.get('Y', None)
                width = dims.get('X', None)
                
                # Spatial dimension fallback if axes labels are missing
                if height is None or width is None:
                    if len(shape) == 2:
                        height, width = shape
                    elif len(shape) >= 3:
                        min_dim_idx = shape.index(min(shape))
                        spatial_dims = [dim for idx, dim in enumerate(shape) if idx != min_dim_idx]
                        height, width = spatial_dims[0], spatial_dims[1]
                
                if height and width:
                    area = height * width
                    if area > max_area:
                        max_area = area
                        best_shape = (height, width)
            
            if best_shape:
                height, width = best_shape
                # 1/n of the smaller spatial dimension of the largest resolution series
                return min(height, width) // int(config['chunk_ratio'])
    except Exception:
        pass
    
    return default_chunk

# Set up a function determining all input
def all_input(wildcards):
    input_list = []
    # Add TIF converted from VSI if necessary
    vsi = [image for image in list(sample['input_image']) if ".vsi" in image]
    if len(vsi) > 0: 
        input_list.extend(expand("{out_converted}/{name}/converted.ome.tif",
                                 out_converted=config['out_converted'],
                                 name=list(sample.index))
                          )

    # Add more files using normalized intensities
    if config['norm_method'] != "":
        if config['thresholding'] == "":
            input_list.extend(expand("{out_masked}/{name}/native_thresholding.zarr",
                                     out_masked=config['out_masked'],
                                     name=list(multi_channel.index))
                              )

        else: 
            input_list.extend(expand("{out_masked}/{name}/merge_channels.html",
                                     out_masked=config['out_masked'],
                                     name=list(multi_channel.index))
                              )
    # Specify QC results
    else:
        input_list.extend(expand("{out_masked}/{name}/qc_normalization.zarr",
                                 out_masked=config['out_masked'],
                                 name=list(multi_channel.index))
                          )
    return input_list

rule all:
    input:
        all_input

rule convert:
    """
    This rule converts VSI images to OME-TIFF format 
    using the bftools package
    """
    input: 
        vsi = lambda wildcards: sample.loc[wildcards.name, 'input_image'],
        rmd = "image_conversion.Rmd"
    output: 
        tif = "{out_converted}/{name}/converted.ome.tif",
        html = "{out_converted}/{name}/image_conversion.html"
    threads: 1
    resources:
        mem_mb = 1024 * 40,
        disk_mb = 1024 * 20,
        runtime = 60 * 12
    params:
        series = config['ser'],
        pyramidal = config['pyramidal'],
        conda_env = config['conda_env']
    shell:
        """
        Rscript -e 'params = list(
            vsi = "{input.vsi}",
            tif = "{output.tif}",
            input_meta_out = "{wildcards.out_converted}/{wildcards.name}/input_metadata.txt",
            output_meta_out = "{wildcards.out_converted}/{wildcards.name}/output_metadata.txt",
            ser = "{params.series}",
            conda_env = "{params.conda_env}",
            to_pyramidal = "{params.pyramidal}");
        rmarkdown::render("{input.rmd}",
            output_dir = "{wildcards.out_converted}/{wildcards.name}",
            intermediates_dir = "{wildcards.out_converted}/{wildcards.name}",
            params = params,
            output_file = "{output.html}")'
        """

rule build_imagecontainer:
    """
    This rule builds a Squidpy ImageContainer object
    from an OME-TIFF image input
    """
    input:
        tif = config['out_converted'] + "/{name}/converted.ome.tif",
        rmd = "build_imagecontainer.Rmd"
    output:
        zarr = directory("{out_masked}/{name}/build_imagecontainer.zarr"),
        html = "{out_masked}/{name}/build_imagecontainer.html",
    threads: 12
    resources:
        mem_mb = 1024 * 200,
        disk_mb = 1024 * 100,
        runtime = 60 * 2
    params:
        conda_env = config['conda_env'],
        lyr = config['lyr'],
        chunksize = get_chunksize,
        crop = config['crop_images'],
        crop_height = config['crop_height'],
        crop_width = config['crop_width'],
        crop_size = config['crop_size'],
        crop_scale = config['crop_scale']
    shell:
        """
        Rscript -e 'params = list(
            outdir = "{wildcards.out_masked}/{wildcards.name}",
            input_image = "{input.tif}",
            output_obj = "{output.zarr}",
            conda_env = "{params.conda_env}",
            lyr = "{params.lyr}",
            chunksize = "{params.chunksize}",
            crop_images = "{params.crop}",
            crop_height = "{params.crop_height}",
            crop_width = "{params.crop_width}",
            crop_size = "{params.crop_size}",
            crop_scale = "{params.crop_scale}");
        rmarkdown::render("{input.rmd}",
            output_dir = "{wildcards.out_masked}/{wildcards.name}",
            intermediates_dir = "{wildcards.out_masked}/{wildcards.name}",
            params = params,
            output_file = "{output.html}")'
        """

